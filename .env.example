# Discord
DISCORD_TOKEN=your_bot_token
DISCORD_USER_ID=your_discord_user_id
CHANNEL_IDS=123456789,987654321

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Daily summary (UTC)
SUMMARY_UTC_HOUR=8
SUMMARY_UTC_MINUTE=0

# Weekly summary (UTC) - day 0=Mon, 6=Sun
SUMMARY_WEEKLY_DAY=6
SUMMARY_WEEKLY_UTC_HOUR=9
SUMMARY_WEEKLY_UTC_MINUTE=0

# Optional: override data paths (default: ./data/)
# STATE_PATH=./data/state.json
# DB_PATH=./data/summaries.db
